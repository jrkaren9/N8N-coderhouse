      "id": "aa605e0f-c3b2-4150-9a65-972f8799e447",
      "name": "Wiktionary"
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "function uniquePreserveOrder(values) {\n  const seen = new Set();\n  const result = [];\n\n  for (const value of values) {\n    if (value && !seen.has(value)) {\n      seen.add(value);\n      result.push(value);\n    }\n  }\n\n  return result;\n}\n\nfunction limitList(values, max = 8) {\n  if (values.length <= max) return values;\n  return [...values.slice(0, max), '...'];\n}\n\nfunction escapeHtml(text) {\n  return String(text ?? '')\n    .replace(/&/g, '&amp;')\n    .replace(/</g, '&lt;')\n    .replace(/>/g, '&gt;')\n    .replace(/\"/g, '&quot;')\n    .replace(/'/g, '&#39;');\n}\n\nconst data = $input.item.json;\n\nconst word = data.word ?? '';\nconst entries = data.entries ?? [];\n\nlet senseCounter = 1;\nconst sections = [];\n\nfor (const entry of entries) {\n  const partOfSpeech = entry.partOfSpeech ?? '-';\n  const senses = entry.senses ?? [];\n\n  if (!senses.length) {\n    sections.push(`\n      <div style=\"margin-bottom:16px;\">\n        <div style=\"font-weight:700; margin-bottom:6px;\">${senseCounter}. No definition available</div>\n        <div><strong>Part of speech:</strong> ${escapeHtml(partOfSpeech)}</div>\n        <div><strong>Korean:</strong> -</div>\n        <div><strong>Spanish:</strong> -</div>\n      </div>\n    `);\n    senseCounter++;\n    continue;\n  }\n\n  for (const sense of senses) {\n    const definition = sense.definition ?? 'No definition available';\n\n    let translations = sense.translations ?? [];\n    if (!translations.length) {\n      translations = entry.translations ?? [];\n    }\n\n    const koreanWords = [];\n    const spanishWords = [];\n\n    for (const tr of translations) {\n      const code = tr.language?.code ?? '';\n      const translatedWord = tr.word ?? '';\n\n      if (code === 'ko' && translatedWord) koreanWords.push(translatedWord);\n      if (code === 'es' && translatedWord) spanishWords.push(translatedWord);\n    }\n\n    const uniqueKorean = limitList(uniquePreserveOrder(koreanWords), 6);\n    const uniqueSpanish = limitList(uniquePreserveOrder(spanishWords), 8);\n\n    sections.push(`\n      <div style=\"margin-bottom:16px;\">\n        <div style=\"font-weight:700; margin-bottom:6px;\">\n          ${senseCounter}. ${escapeHtml(definition)}\n        </div>\n        <div><strong>Part of speech:</strong> ${escapeHtml(partOfSpeech)}</div>\n        <div><strong>Korean:</strong> ${uniqueKorean.length ? escapeHtml(uniqueKorean.join(', ')) : '-'}</div>\n        <div><strong>Spanish:</strong> ${uniqueSpanish.length ? escapeHtml(uniqueSpanish.join(', ')) : '-'}</div>\n      </div>\n    `);\n\n    senseCounter++;\n  }\n}\n\nconst formatted_html = `\n  <div style=\"margin-bottom:28px;\">\n    <h2 style=\"margin:0 0 14px 0; font-size:22px;\">Word: ${escapeHtml(word)}</h2>\n    ${sections.join('')}\n  </div>\n`;\n\nreturn {\n  json: {\n    word,\n    formatted_html,\n  },\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        640,
