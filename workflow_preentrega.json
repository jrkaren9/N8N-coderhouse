    {
      "parameters": {
        "jsCode": "const blocks = $input.all()\n  .map(item => item.json.formatted_html)\n  .filter(Boolean);\n\nconst original = $('Obtain data').first().json;\nconst name = original.body?.name ?? '';\n\nconst emailBody = `\n  <div style=\"font-family: Arial, Helvetica, sans-serif; font-size: 16px; line-height: 1.5; color: #222;\">\n    <p>Hi ${name},</p>\n    <p>Here are your definitions from Wiktionary:</p>\n\n    ${blocks.join('<hr style=\"border:none; border-top:1px solid #ddd; margin:24px 0;\">')}\n  </div>\n`;\n\nreturn [\n  {\n    json: {\n      emailBody,\n      name,\n      email: original.body?.email ?? '',\n    }\n  }\n];"
      },
